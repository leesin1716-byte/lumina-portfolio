# --- Supabase (Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- TossPayments (test keys to start: 결제 → API 키) ---
NEXT_PUBLIC_TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=

# --- Site ---
# 배포 도메인. canonical/OG/sitemap/manifest URL의 기준이 됩니다.
# 프로덕션에서는 실제 주소로 설정하세요 (예: https://your-domain.com).
# 비우면 기본값(lumina-portfolio.vercel.app)을 사용합니다.
# NEXT_PUBLIC_ 변수는 빌드 시 인라인되므로 빌드 전에 설정해야 합니다.
NEXT_PUBLIC_SITE_URL=https://your-domain.com
